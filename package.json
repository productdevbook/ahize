{
  "name": "ahize",
  "version": "0.0.1",
  "description": "Zero-dependency TypeScript wrappers for live chat & customer support widgets — Intercom, Crisp, Tawk.to, Zendesk, HubSpot and more. Unified API, tree-shakeable.",
  "keywords": [
    "ahize",
    "chat-widget",
    "chatwoot",
    "crisp",
    "customer-support",
    "drift",
    "esm",
    "freshchat",
    "helpscout",
    "hubspot",
    "intercom",
    "live-chat",
    "livechat",
    "olark",
    "self-hosted",
    "smartsupp",
    "tawk",
    "tree-shakeable",
    "typescript",
    "userlike",
    "zendesk",
    "zero-dependency"
  ],
  "homepage": "https://github.com/productdevbook/ahize",
  "bugs": {
    "url": "https://github.com/productdevbook/ahize/issues"
  },
  "license": "MIT",
  "author": "productdevbook",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/productdevbook/ahize.git"
  },
  "funding": "https://github.com/sponsors/productdevbook",
  "files": [
    "dist"
  ],
  "type": "module",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./intercom": {
      "types": "./dist/providers/intercom.d.mts",
      "default": "./dist/providers/intercom.mjs"
    },
    "./crisp": {
      "types": "./dist/providers/crisp.d.mts",
      "default": "./dist/providers/crisp.mjs"
    },
    "./tawk": {
      "types": "./dist/providers/tawk.d.mts",
      "default": "./dist/providers/tawk.mjs"
    },
    "./zendesk": {
      "types": "./dist/providers/zendesk.d.mts",
      "default": "./dist/providers/zendesk.mjs"
    },
    "./zendesk-classic": {
      "types": "./dist/providers/zendesk-classic.d.mts",
      "default": "./dist/providers/zendesk-classic.mjs"
    },
    "./hubspot": {
      "types": "./dist/providers/hubspot.d.mts",
      "default": "./dist/providers/hubspot.mjs"
    },
    "./chatwoot": {
      "types": "./dist/providers/chatwoot.d.mts",
      "default": "./dist/providers/chatwoot.mjs"
    },
    "./livechat": {
      "types": "./dist/providers/livechat.d.mts",
      "default": "./dist/providers/livechat.mjs"
    },
    "./drift": {
      "types": "./dist/providers/drift.d.mts",
      "default": "./dist/providers/drift.mjs"
    },
    "./freshchat": {
      "types": "./dist/providers/freshchat.d.mts",
      "default": "./dist/providers/freshchat.mjs"
    },
    "./olark": {
      "types": "./dist/providers/olark.d.mts",
      "default": "./dist/providers/olark.mjs"
    },
    "./userlike": {
      "types": "./dist/providers/userlike.d.mts",
      "default": "./dist/providers/userlike.mjs"
    },
    "./helpscout": {
      "types": "./dist/providers/helpscout.d.mts",
      "default": "./dist/providers/helpscout.mjs"
    },
    "./smartsupp": {
      "types": "./dist/providers/smartsupp.d.mts",
      "default": "./dist/providers/smartsupp.mjs"
    },
    "./liveagent": {
      "types": "./dist/providers/liveagent.d.mts",
      "default": "./dist/providers/liveagent.mjs"
    },
    "./gist": {
      "types": "./dist/providers/gist.d.mts",
      "default": "./dist/providers/gist.mjs"
    },
    "./jivochat": {
      "types": "./dist/providers/jivochat.d.mts",
      "default": "./dist/providers/jivochat.mjs"
    },
    "./tidio": {
      "types": "./dist/providers/tidio.d.mts",
      "default": "./dist/providers/tidio.mjs"
    },
    "./sendbird": {
      "types": "./dist/providers/sendbird.d.mts",
      "default": "./dist/providers/sendbird.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "default": "./dist/server.mjs"
    },
    "./csp": {
      "types": "./dist/csp.d.mts",
      "default": "./dist/csp.mjs"
    },
    "./facade": {
      "types": "./dist/facade.d.mts",
      "default": "./dist/facade.mjs"
    },
    "./capabilities": {
      "types": "./dist/capabilities.d.mts",
      "default": "./dist/capabilities.mjs"
    },
    "./diagnostics": {
      "types": "./dist/diagnostics.d.mts",
      "default": "./dist/diagnostics.mjs"
    }
  },
  "scripts": {
    "build": "obuild",
    "dev": "vitest",
    "lint": "oxlint . && oxfmt --check .",
    "lint:fix": "oxlint . --fix && oxfmt .",
    "fmt": "oxfmt .",
    "test": "pnpm lint && pnpm typecheck && vitest run",
    "typecheck": "tsgo --noEmit",
    "release": "pnpm test && pnpm build && bumpp --commit --tag --push --all",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "jsdom": "^29.0.2",
    "obuild": "^0.4.32",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
